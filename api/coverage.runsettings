<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <!-- API ユニットテストでは Engine アセンブリの行カバレッジは計測しない -->
          <Exclude>[Statevia.Core.Engine]*</Exclude>
          <!-- Program / Migrations は統合テストがなく単体では網羅困難なため除外 -->
          <ExcludeByFile>**/Program.cs</ExcludeByFile>
          <ExcludeByFile>**/Migrations/**</ExcludeByFile>
          <Format>cobertura</Format>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
