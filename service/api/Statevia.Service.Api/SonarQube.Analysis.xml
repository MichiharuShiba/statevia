<?xml version="1.0" encoding="utf-8" ?>
<!--
  SonarScanner for .NET / SonarQube for IDE（プロジェクトスコープ）向け。
  Migrations / Engine / UI / テストは API プロジェクトキー（StateviaCoreAPI）の対象外。
  sonar-scanner-api.ps1 の begin パラメータと整合させる。
-->
<SonarQubeAnalysisProperties xmlns="http://www.sonarsource.com/schemas/2021/1/SonarQubeAnalysisProperties">
  <Property Name="sonar.exclusions">**/Migrations/**,**/ui/studio/**,**/core/engine/**,**/engine/**,**/Statevia.Core.Engine/**,**/*.Tests/**,**/Program.cs,**/Dockerfile</Property>
</SonarQubeAnalysisProperties>
