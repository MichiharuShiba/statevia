<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Statevia.Service.Api</RootNamespace>
    <AssemblyName>Statevia.Service.Api</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- CA2007: ASP.NET Core では既定で SynchronizationContext が掛からないため、ライブラリ向けの ConfigureAwait 指摘はノイズとなる。 -->
    <NoWarn>$(NoWarn);CA2007</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="Statevia.Core.Actions.Abstractions.Modules" />
    <Using Include="Statevia.Core.Application.Contracts.Persistence" />
    <Using Include="Statevia.Core.Application.Contracts.Security" />
    <Using Include="Statevia.Core.Application.Contracts.Services" />
    <Using Include="Statevia.Service.Api.Application.Security" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Statevia.Service.Api.Tests" />
    <InternalsVisibleTo Include="Statevia.Service.Api.Bootstrap" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.10" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Persistence/Statevia.Infrastructure.Persistence.csproj" />
    <PackageReference Include="OrasProject.Oras" Version="0.5.0" />
    <PackageReference Include="Scalar.AspNetCore" Version="2.14.14" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.9.0" />
    <PackageReference Include="Microsoft.Extensions.Identity.Core" Version="8.0.10" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.2.1" />
    <ProjectReference Include="../../../core/engine/Statevia.Core.Engine/Statevia.Core.Engine.csproj" />
    <ProjectReference Include="../../../core/actions/Statevia.Core.Actions.Abstractions/Statevia.Core.Actions.Abstractions.csproj" />
    <ProjectReference Include="../../../core/application/Statevia.Core.Application.Contracts/Statevia.Core.Application.Contracts.csproj" />
    <ProjectReference Include="../../../shared/Statevia.Actions.Grpc/Statevia.Actions.Grpc.csproj" />
    <ProjectReference Include="../../../shared/Statevia.Modules/Statevia.Modules.csproj" />
    <PackageReference Include="Grpc.Net.Client" Version="2.67.0" />
  </ItemGroup>

</Project>
