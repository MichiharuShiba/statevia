<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Statevia.Service.Api</RootNamespace>
    <AssemblyName>Statevia.Service.Api</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- CA2007: ASP.NET Core では既定で SynchronizationContext が掛からないため、ライブラリ向けの ConfigureAwait 指摘はノイズとなる。 -->
    <NoWarn>$(NoWarn);CA2007</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="Statevia.Core.Actions.Abstractions.Modules" />
    <Using Include="Statevia.Core.Application.Contracts" />
    <Using Include="Statevia.Core.Application.Contracts.Persistence" />
    <Using Include="Statevia.Core.Application.Contracts.Security" />
    <Using Include="Statevia.Core.Application.Contracts.Services" />
    <Using Include="Statevia.Core.Application.Services" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Statevia.Service.Api.Tests" />
    <InternalsVisibleTo Include="Statevia.Service.Api.Bootstrap" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.10">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Scalar.AspNetCore" Version="2.14.14" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.9.0" />
    <PackageReference Include="Grpc.Net.Client" Version="2.67.0" />
    <ProjectReference Include="../../../core/engine/Statevia.Core.Engine/Statevia.Core.Engine.csproj" />
    <ProjectReference Include="../../../core/actions/Statevia.Core.Actions.Abstractions/Statevia.Core.Actions.Abstractions.csproj" />
    <ProjectReference Include="../../../core/application/Statevia.Core.Application.Contracts/Statevia.Core.Application.Contracts.csproj" />
    <ProjectReference Include="../../../core/application/Statevia.Core.Application/Statevia.Core.Application.csproj" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Persistence/Statevia.Infrastructure.Persistence.csproj" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Security/Statevia.Infrastructure.Security.csproj" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Notification/Statevia.Infrastructure.Notification.csproj" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Modules/Statevia.Infrastructure.Modules.csproj" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Common/Statevia.Infrastructure.Common.csproj" />
    <ProjectReference Include="../../../infrastructure/Statevia.Infrastructure.Actions.Grpc/Statevia.Infrastructure.Actions.Grpc.csproj" />
  </ItemGroup>

</Project>
